{
  "compilerOptions": {
    "rootDir": "src",
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "skipLibCheck": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitOverride": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ]
}